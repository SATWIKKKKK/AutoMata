# .env.example
# Database & Cache
DATABASE_URL=postgresql://username:password@ep-example.us-east-1.aws.neon.tech/neondb?sslmode=require
# DATABASE_FILE=orren.db
REDIS_URL=redis://localhost:6379/0

# AI Models & Keys
GEMINI_API_KEY=
ANTHROPIC_API_KEY=

ANTHROPIC_MODELS_ALLOWED=claude-3-5-sonnet-20241022,claude-3-5-haiku-20241022

# Authentication
JWT_SECRET=super_secret_change_me
FERNET_KEY=  # Generated via cryptography.fernet.generate_key()
ENCRYPTION_KEY=replace_with_64_char_hex_key

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/api/integrations/callback/google
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_TOKEN=

# Infrastructure
TEMPORAL_HOST=localhost:7233
FRONTEND_URL=http://localhost:3000
USD_TO_INR_RATE=84
NODE_ENV=production
